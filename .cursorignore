build/
out/
.next/
.nuxt/
.output/
coverage/
target/
bin/
obj/
release/
debug/
.gradle/
.dart_tool/

# Generated files
*.g.dart
*.freezed.dart
*.generated.*
*.gen.*
*.pb.go
*.pb.dart
*.designer.cs
*.lockb

# Logs and temp
*.log
logs/
tmp/
temp/
.cache/
.cache-loader/
.eslintcache/
.parcel-cache/
.turbo/

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.crt
*.p12
*.pfx
*.jks
*.keystore
secrets/
credentials/
service-account*.json
google-services.json
