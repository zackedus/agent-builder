# Large files
*.zip
*.rar
*.7z
*.tar
*.gz
*.mp4
*.mov
*.avi
*.mkv
*.pdf
*.docx
*.xlsx
*.psd
*.ai

# Database dumps/backups
*.sql
*.sqlite
*.db
*.dump
backup/
backups/
archive/
old/
legacy/
