# Anthropic (required for Planner, Reviewer, complex Coder tasks)
ANTHROPIC_API_KEY=
CLAUDE_MODEL_OPUS=claude-opus-4-20250514
CLAUDE_MODEL_SONNET=claude-sonnet-4-20250514

# Ollama (optional; local fallback for scaffold/embeddings)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL_CODER=qwen2.5-coder:14b
